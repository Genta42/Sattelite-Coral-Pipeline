for day in range(1, 31):
    d = date(2025, 11, day)

    # หมูหวาน: 3-day cycle, free when (day-1)%3==0, except Nov 7
    mw = (day - 1) % 3 == 0 and d != date(2025, 11, 7)

    # เจสซี่: free on Mon(0), Tue(1), Wed(2), Fri(4), Sun(6), except Nov 7
    je = d.weekday() in [0, 1, 2, 4, 6] and d != date(2025, 11, 7)

    # นานิ & หมีพูห์: 4-day cycle, free when (day-1)%4==0, but NOT multiples of 3
    np_ = (day - 1) % 4 == 0 and day % 3 != 0

    # รุ่นพี่: free if day not in busy set
    sr = day not in senior_busy

    all_free = mw and je and np_ and sr
    marker = " <<<< ALL FREE!" if all_free else ""

    print(f"Nov {day:<3} {day_names_en[d.weekday()]:<6} {str(mw):<8} {str(je):<8} {str(np_):<10} {str(sr):<8} {str(all_free)}{marker}")

    if all_free and found_date is None:
        found_date = d

