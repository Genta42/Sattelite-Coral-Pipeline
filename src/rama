#
# นานิ & หมีพูห์ (Nani & Pooh): free every 4 days
#   → (day-1) % 4 == 0 → days 1, 5, 9, 13, 17, 21, 25, 29
#   But NOT when day-of-month is a multiple of 3
#
# รุ่นพี่ (Seniors): busy on days 1, 3, 8, 12, 15, 19 of the month
#
# คุณ (You): no constraints mentioned → always free

senior_busy = {1, 3, 8, 12, 15, 19}

print("\nNovember 2025 — Full availability analysis:")
